# PII tokenizer config. Copy to `.env` (gitignored) and adjust. NEVER commit real secrets.

# --- Token store (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Encryption (HashiCorp Vault transit engine) ---
VAULT_ADDR=http://127.0.0.1:8200
# Dev-mode root token; matches VAULT_DEV_ROOT_TOKEN_ID in docker-compose.yml.
# Replace with a scoped token (transit encrypt/decrypt only) for anything beyond local dev.
VAULT_TOKEN=pii-root-token
VAULT_TRANSIT_KEY=pii

# --- PII detection (Microsoft Presidio analyzer, HTTP) ---
PRESIDIO_URL=http://localhost:5002

# Token expiry in seconds; 0 = never expire (keeps detokenization working across sessions).
TOKEN_TTL=0

# High-confidence Presidio entities to tokenize. API keys/secrets are matched separately by
# regex in pii_vault.py (SECRET_PATTERNS), independent of Presidio.
PII_ENTITIES=CREDIT_CARD,US_SSN,EMAIL_ADDRESS,PHONE_NUMBER,IBAN_CODE

# Minimum Presidio score (0-1) to accept a detection. 0.4 catches loosely-formatted phones;
# the identifier guard in pii_vault.py prevents the resulting false positives on code/versions.
PII_SCORE_THRESHOLD=0.4

# Skip tokenizing tool outputs larger than this many chars (latency guard); 0 = no limit.
MAX_TOKENIZE_CHARS=20000
