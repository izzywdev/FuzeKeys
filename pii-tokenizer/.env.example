# PII tokenizer config. Copy to `.env` (gitignored) and adjust. NEVER commit real secrets.

# --- Token store (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Encryption (HashiCorp Vault transit engine, PERSISTENT file storage) ---
VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN is managed automatically: stack-up.sh initializes the persistent Vault once,
# stores the unseal key + root token in vault/.vault-init.json (gitignored), and writes the
# root token back into this line on every run. Leave the placeholder below for a fresh setup.
# For non-local use, swap to a token scoped to transit encrypt/decrypt only.
VAULT_TOKEN=set-by-stack-up
VAULT_TRANSIT_KEY=pii

# --- PII detection (Microsoft Presidio analyzer, HTTP) ---
PRESIDIO_URL=http://localhost:5002

# Token expiry in seconds. 86400 = 24h (tokens auto-expire from Redis after a day).
TOKEN_TTL=86400

# High-confidence Presidio entities to tokenize. API keys/secrets are matched separately by
# regex in pii_vault.py (SECRET_PATTERNS), independent of Presidio.
PII_ENTITIES=CREDIT_CARD,US_SSN,EMAIL_ADDRESS,PHONE_NUMBER,IBAN_CODE

# Minimum Presidio score (0-1) to accept a detection. 0.4 catches loosely-formatted phones;
# the identifier guard in pii_vault.py prevents the resulting false positives on code/versions.
PII_SCORE_THRESHOLD=0.4

# Skip tokenizing tool outputs larger than this many chars (latency guard); 0 = no limit.
MAX_TOKENIZE_CHARS=20000

# --- Feature 2: LLM second-stage PII detection (local Ollama / Gemma) ---
# Opt-in flag. Set to true to enable Gemma-based second-stage detection AFTER Presidio + regex.
# Fail-open: if Ollama is unreachable or returns an error, detection falls back to Presidio+regex
# only (no exception is raised; tokenization continues as normal).
# NOTE: Ollama runs locally only — no data leaves the host. Do NOT point OLLAMA_URL at a remote.
LLM_PII_DETECTION=false

# Base URL of the Ollama API server (default: local).
OLLAMA_URL=http://localhost:11434

# Ollama model to use for PII detection. Pull it first:
#   docker exec pii-ollama ollama pull gemma3:4b
OLLAMA_PII_MODEL=gemma3:4b

# Skip LLM detection for inputs longer than this many chars (latency guard).
LLM_PII_MAX_CHARS=8000

# HTTP timeout in seconds for the Ollama API call.
LLM_PII_TIMEOUT=30
