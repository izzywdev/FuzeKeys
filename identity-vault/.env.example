# Identity-vault config. Copy to `.env` (gitignored) and adjust. NEVER commit real secrets.

# --- OpenBao (machine/agent secrets; Vault-compatible API) ---
BAO_ADDR=http://127.0.0.1:8210
OPENBAO_KV_MOUNT=kv
# Managed by stack-up.sh: it initializes OpenBao once, stores the unseal key + root token
# in openbao/.openbao-init.json (gitignored), and writes a policy-scoped broker token here.
OPENBAO_BROKER_TOKEN=set-by-stack-up

# --- Vaultwarden (identity PII + cards + logins; client-side crypto) ---
VW_ADDR=http://127.0.0.1:8222
VW_DOMAIN=http://localhost:8222
# Admin token for the /admin panel. Prefer an argon2 PHC hash:
#   docker run --rm vaultwarden/server /vaultwarden hash   (paste the $argon2id$... output)
# A plain string also works for local dev (Vaultwarden logs a warning).
VW_ADMIN_TOKEN=change-me-before-first-run

# The broker authenticates to Vaultwarden via a dedicated service account (Bitwarden API).
# Create it in the Vaultwarden UI after first run, then set these (broker reads them):
VW_SERVICE_EMAIL=broker@identity-vault.local
VW_SERVICE_PASSWORD=set-after-first-run
